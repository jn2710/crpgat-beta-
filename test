<!DOCTYPE html>
<html>
<head>
  <title>CRPGAT Survival+</title>
  <style>
    body { margin: 0; overflow: hidden; background: #111; }
    canvas { display: block; }
  </style>
</head>
<body>
<canvas id="game"></canvas>
<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

function resize() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
}
resize();
window.addEventListener("resize", resize);

// =====================
// GAME STATE
// =====================
const player = {
  x: 400,
  y: 300,
  hp: 100,
  speed: 3,
  hitFlash: 0
};

const game = {
  round: 1,
  points: 0,
  state: "playing",
  zombiesToSpawn: 0,
  spawnDelay: 40,
  spawnTick: 0,
  paused: false
};

let zombies = [];
let bullets = [];
let particles = [];
let barricades = [];

let keys = {};
let mouse = { x: 0, y: 0 };

// =====================
// WEAPON
// =====================
let weapon = {
  name: "pistol",
  ammo: 12,
  maxAmmo: 12,
  reload: 800,
  damage: 20,
  fireRate: 200,
  spread: 0,
  pellets: 1,
  lastShot: 0
};

let reloading = false;

// =====================
// INPUT
// =====================
document.addEventListener("keydown", e => {
  keys[e.key.toLowerCase()] = true;

  if (e.key === "r") reload();
  if (e.key === "e") buyBox();
  if (e.key === "f") repairBarricades();
  if (e.key === "p") game.paused = !game.paused;
});
document.addEventListener("keyup", e => keys[e.key.toLowerCase()] = false);

canvas.addEventListener("mousemove", e => {
  mouse.x = e.clientX;
  mouse.y = e.clientY;
});

canvas.addEventListener("mousedown", shoot);

// =====================
function dist(a,b) {
  return Math.hypot(a.x - b.x, a.y - b.y);
}

// =====================
// ROUNDS
// =====================
function startRound() {
  game.state = "playing";
  game.zombiesToSpawn = 5 + game.round * 4;
  game.spawnTick = 0;

  // small barricade regen
  barricades.forEach(b => {
    b.hp = Math.min(b.maxHp, b.hp + 20);
  });
}

function endRound() {
  game.state = "between";
  setTimeout(() => {
    game.round++;
    startRound();
  }, 2000);
}

startRound();

// =====================
// ZOMBIES
// =====================
function spawnZombie() {
  if (game.zombiesToSpawn <= 0) return;

  let z;
  const roll = Math.random();

  if (roll < 0.2) {
    z = { hp: 25, speed: 2.8, size: 8, color: "#7CFC00" };
  } else if (roll > 0.85) {
    z = { hp: 140, speed: 0.7, size: 14, color: "#145214" };
  } else {
    z = { hp: 60, speed: 1.5, size: 10, color: "lime" };
  }

  // spawn off-screen
  const edge = Math.floor(Math.random() * 4);
  if (edge === 0) { z.x = -20; z.y = Math.random()*canvas.height; }
  if (edge === 1) { z.x = canvas.width+20; z.y = Math.random()*canvas.height; }
  if (edge === 2) { z.x = Math.random()*canvas.width; z.y = -20; }
  if (edge === 3) { z.x = Math.random()*canvas.width; z.y = canvas.height+20; }

  zombies.push(z);
  game.zombiesToSpawn--;
}

// =====================
// BARRICADES
// =====================
function initBarricades() {
  for (let i = 0; i < 12; i++) {
    barricades.push({
      x: Math.random()*canvas.width,
      y: Math.random()*canvas.height,
      hp: 100,
      maxHp: 100
    });
  }
}
initBarricades();

function repairBarricades() {
  barricades.forEach(b => {
    if (dist(player,b) < 40 && game.points >= 10) {
      b.hp = Math.min(b.maxHp, b.hp + 10);
      game.points -= 10;
    }
  });
}

// =====================
// SHOOTING
// =====================
function shoot() {
  const now = Date.now();
  if (now - weapon.lastShot < weapon.fireRate) return;
  if (weapon.ammo <= 0 || reloading) return;

  weapon.lastShot = now;
  weapon.ammo--;

  const baseAngle = Math.atan2(mouse.y - player.y, mouse.x - player.x);

  for (let i = 0; i < weapon.pellets; i++) {
    const spread = (Math.random() - 0.5) * weapon.spread;
    const angle = baseAngle + spread;

    bullets.push({
      x: player.x,
      y: player.y,
      vx: Math.cos(angle) * 8,
      vy: Math.sin(angle) * 8,
      dmg: weapon.damage
    });
  }

  shake = 6;
}

// =====================
function reload() {
  if (reloading || weapon.ammo === weapon.maxAmmo) return;

  reloading = true;

  setTimeout(() => {
    weapon.ammo = weapon.maxAmmo;
    reloading = false;
  }, weapon.reload);
}

// =====================
// BOX
// =====================
const box = { x: 300, y: 250, cost: 500 };

function buyBox() {
  if (dist(player, box) > 50) return;
  if (game.points < box.cost) return;

  game.points -= box.cost;

  const roll = Math.random();

  if (roll < 0.4) {
    weapon = { name:"rifle", ammo:30, maxAmmo:30, reload:1200, damage:15, fireRate:90, spread:0.05, pellets:1, lastShot:0 };
  } else if (roll < 0.7) {
    weapon = { name:"shotgun", ammo:6, maxAmmo:6, reload:1500, damage:8, fireRate:500, spread:0.6, pellets:6, lastShot:0 };
  } else {
    weapon = { name:"sniper", ammo:5, maxAmmo:5, reload:1800, damage:80, fireRate:800, spread:0.01, pellets:1, lastShot:0 };
  }
}

// =====================
let shake = 0;

function spawnHit(x,y) {
  for (let i=0;i<8;i++) {
    particles.push({
      x,y,
      vx:(Math.random()-0.5)*5,
      vy:(Math.random()-0.5)*5,
      life:20
    });
  }
}

// =====================
// UPDATE
// =====================
function update() {
  if (game.paused) return;

  if (player.hp <= 0) {
    game.state = "gameover";
    return;
  }

  // sprint
  let speed = player.speed;
  if (keys["shift"]) {
    speed *= 1.8;
    player.hp -= 0.02;
  }

  if (keys["w"]) player.y -= speed;
  if (keys["s"]) player.y += speed;
  if (keys["a"]) player.x -= speed;
  if (keys["d"]) player.x += speed;

  // clamp to screen
  player.x = Math.max(0, Math.min(canvas.width, player.x));
  player.y = Math.max(0, Math.min(canvas.height, player.y));

  // bullets
  bullets.forEach(b => {
    b.x += b.vx;
    b.y += b.vy;
  });

  bullets = bullets.filter(b =>
    b.x > 0 && b.x < canvas.width &&
    b.y > 0 && b.y < canvas.height
  );

  // spawn
  if (game.state === "playing") {
    game.spawnTick++;
    if (game.spawnTick > game.spawnDelay) {
      spawnZombie();
      game.spawnTick = 0;
    }
    if (game.zombiesToSpawn === 0 && zombies.length === 0) {
      endRound();
    }
  }

  // zombies
  zombies.forEach((z,i) => {

    // separation
    zombies.forEach((o,j) => {
      if (i !== j) {
        const d = dist(z,o);
        if (d < 20 && d > 0) {
          z.x += (z.x - o.x) * 0.02;
          z.y += (z.y - o.y) * 0.02;
        }
      }
    });

    let blocked = false;

    barricades.forEach(b => {
      if (dist(z,b) < 14 && b.hp > 0) {
        b.hp -= 0.3;
        blocked = true;
      }
    });

    if (!blocked) {
      const ang = Math.atan2(player.y-z.y, player.x-z.x);
      z.x += Math.cos(ang)*z.speed;
      z.y += Math.sin(ang)*z.speed;
    }

    if (dist(z, player) < 15) {
      player.hp -= 0.2;
      player.hitFlash = 5;
      shake = 8;
    }
  });

  // collisions
  for (let i=zombies.length-1;i>=0;i--) {
    for (let j=bullets.length-1;j>=0;j--) {
      if (dist(zombies[i], bullets[j]) < 15) {
        zombies[i].hp -= bullets[j].dmg;
        spawnHit(zombies[i].x, zombies[i].y);
        bullets.splice(j,1);
        game.points += 10;

        if (zombies[i].hp <= 0) {
          zombies.splice(i,1);
          game.points += 50;
        }
        break;
      }
    }
  }

  // particles
  particles.forEach(p => {
    p.x += p.vx;
    p.y += p.vy;
    p.life--;
  });
  particles = particles.filter(p => p.life > 0);

  if (player.hitFlash > 0) player.hitFlash--;
}

// =====================
// DRAW
// =====================
function draw() {
  ctx.save();

  if (shake > 0) {
    ctx.translate((Math.random()-0.5)*shake,(Math.random()-0.5)*shake);
    shake *= 0.9;
  }

  ctx.clearRect(0,0,canvas.width,canvas.height);

  // barricades
  ctx.fillStyle = "#666";
  barricades.forEach(b => {
    if (b.hp > 0)
      ctx.fillRect(b.x-10,b.y-10,20,20);
  });

  // player
  ctx.fillStyle = player.hitFlash > 0 ? "red" : "cyan";
  ctx.beginPath();
  ctx.arc(player.x, player.y, 10, 0, Math.PI*2);
  ctx.fill();

  // zombies
  zombies.forEach(z => {
    ctx.fillStyle = z.color;
    ctx.fillRect(z.x - z.size/2, z.y - z.size/2, z.size, z.size);
  });

  // bullets
  ctx.fillStyle = "yellow";
  bullets.forEach(b => ctx.fillRect(b.x,b.y,4,4));

  // particles
  ctx.fillStyle = "orange";
  particles.forEach(p => ctx.fillRect(p.x,p.y,2,2));

  // crosshair
  ctx.strokeStyle = "white";
  ctx.beginPath();
  ctx.arc(mouse.x, mouse.y, 6, 0, Math.PI*2);
  ctx.stroke();

  ctx.restore();

  // UI
  ctx.fillStyle = "white";
  ctx.fillText(`HP: ${Math.floor(player.hp)}`, 20, 20);
  ctx.fillText(`Round: ${game.round}`, 20, 40);
  ctx.fillText(`Points: ${game.points}`, 20, 60);
  ctx.fillText(`Weapon: ${weapon.name}`, 20, 80);
  ctx.fillText(`Ammo: ${weapon.ammo}/${weapon.maxAmmo}`, 20, 100);

  if (reloading) ctx.fillText("Reloading...", 20, 120);
  if (game.paused) ctx.fillText("PAUSED", canvas.width/2-30, 40);

  if (game.state === "gameover") {
    ctx.fillStyle = "red";
    ctx.font = "40px Arial";
    ctx.fillText("GAME OVER", canvas.width/2 - 120, canvas.height/2);
  }
}

// =====================
function loop() {
  update();
  draw();
  requestAnimationFrame(loop);
}
loop();
</script>
</body>
</html>
