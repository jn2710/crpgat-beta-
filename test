<!DOCTYPE html>
<html>
<head>
<title>CRPGAT Survival++ EXPANDED</title>
<style>
body { margin:0; overflow:hidden; background:#000; }
canvas { display:block; }
</style>
</head>
<body>
<canvas id="game"></canvas>
<script>

// ================= ORIGINAL SETUP =================
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

function resize(){
canvas.width = innerWidth;
canvas.height = innerHeight;
}
resize();
addEventListener("resize", resize);

// ================= NEW CAMERA =================
const camera = {x:0,y:0};

// ================= PLAYER (UNCHANGED + NEW FIELDS) =================
const player = {
x:400, y:300,
hp:100, maxHp:100,
armor:0.1,
speed:3,
dash:0,
xp:0, level:1, nextLevel:100,
streak:0, multi:1,

// NEW
score:0,
kills:0
};

// ================= GAME (EXPANDED) =================
const game = {
round:1,
paused:false,
zombiesToSpawn:10,
spawnTick:0,
spawnDelay:40,
shake:0,
time:0,

// NEW
biome:0,
flash:0
};

let zombies=[], bullets=[], grenades=[], particles=[], drops=[];

// NEW
let dmgNums=[];
let trail=[];

let keys={}, mouse={x:0,y:0};

// ================= NEW MAP OBJECTS =================
let obstacles=[];
for(let i=0;i<30;i++){
obstacles.push({
x:Math.random()*2000-1000,
y:Math.random()*2000-1000,
w:30+Math.random()*40,
h:30+Math.random()*40
});
}

// ================= ORIGINAL WEAPONS =================
const weapons = {
pistol:{ammo:12,max:12,fire:200,dmg:20,spread:0,pellets:1},
shotgun:{ammo:6,max:6,fire:700,dmg:12,spread:0.5,pellets:6},
smg:{ammo:30,max:30,fire:80,dmg:8,spread:0.2,pellets:1}
};
let currentWeapon="pistol";
let lastShot=0;
let reloading=false;

// ================= INPUT (UNCHANGED) =================
addEventListener("keydown",e=>{
keys[e.key.toLowerCase()]=true;

if(e.key==="1") currentWeapon="pistol";
if(e.key==="2") currentWeapon="shotgun";
if(e.key==="3") currentWeapon="smg";

if(e.key==="r") reload();
});
addEventListener("keyup",e=>keys[e.key.toLowerCase()]=false);

canvas.addEventListener("mousemove",e=>{
mouse.x=e.clientX; mouse.y=e.clientY;
});
canvas.addEventListener("mousedown",shoot);

// ================= UTILS =================
const dist=(a,b)=>Math.hypot(a.x-b.x,a.y-b.y);

// ================= NEW AIM ASSIST =================
function getClosestZombie(){
let best=null, d=9999;
zombies.forEach(z=>{
let di=dist(player,z);
if(di<d){d=di;best=z;}
});
return best;
}

// ================= SHOOT (ENHANCED, ORIGINAL LOGIC KEPT) =================
function shoot(){
const w=weapons[currentWeapon];
const now=Date.now();
if(now-lastShot<w.fire || w.ammo<=0 || reloading) return;

lastShot=now;
w.ammo--;

let base=Math.atan2(mouse.y-player.y,mouse.x-player.x);

// NEW aim assist
const target = getClosestZombie();
if(target && dist(player,target)<150){
base = Math.atan2(target.y-player.y,target.x-player.x);
}

for(let i=0;i<w.pellets;i++){
const angle=base+(Math.random()-0.5)*w.spread;
bullets.push({
x:player.x,y:player.y,
vx:Math.cos(angle)*8,
vy:Math.sin(angle)*8,
dmg:w.dmg
});
}
}

// ================= RELOAD (UNCHANGED) =================
function reload(){
const w=weapons[currentWeapon];
if(reloading||w.ammo===w.max) return;
reloading=true;
setTimeout(()=>{
w.ammo=w.max;
reloading=false;
},600);
}

// ================= SPAWN (EXPANDED TYPES) =================
function spawnZombie(){
if(game.zombiesToSpawn<=0) return;

let z;

// NEW TYPES
let r=Math.random();
if(r<0.1){
z={hp:300,speed:0.7,size:20,color:"purple",boss:true};
}else if(r<0.3){
z={hp:40,speed:3,size:8,color:"orange"};
}else{
z={hp:60,speed:1.5,size:10,color:"lime"};
}

// spawn around player
z.x=player.x+(Math.random()*800-400);
z.y=player.y+(Math.random()*800-400);

zombies.push(z);
game.zombiesToSpawn--;
}

// ================= UPDATE =================
function update(){
if(game.paused||player.hp<=0) return;

game.time++;

// NEW camera follow
camera.x += (player.x - camera.x - canvas.width/2)*0.1;
camera.y += (player.y - camera.y - canvas.height/2)*0.1;

// biome shift
if(game.time%2000===0){
game.biome=(game.biome+1)%3;
}

// movement
let sp=player.speed;
if(keys["shift"] && player.dash<=0) player.dash=20;
if(player.dash>0){ sp*=3; player.dash--; }

if(keys["w"]) player.y-=sp;
if(keys["s"]) player.y+=sp;
if(keys["a"]) player.x-=sp;
if(keys["d"]) player.x+=sp;

// trail
trail.push({x:player.x,y:player.y});
if(trail.length>15) trail.shift();

// spawning
game.spawnTick++;
if(game.spawnTick>game.spawnDelay){
spawnZombie();
game.spawnTick=0;
}

// bullets
for(let i=bullets.length-1;i>=0;i--){
const b=bullets[i];
b.x+=b.vx;
b.y+=b.vy;
}

// zombies
for(let i=zombies.length-1;i>=0;i--){
const z=zombies[i];

const angle=Math.atan2(player.y-z.y,player.x-z.x);
z.x+=Math.cos(angle)*z.speed;
z.y+=Math.sin(angle)*z.speed;

if(dist(z,player)<15){
player.hp-=0.1;
}

// bullet hits
for(let j=bullets.length-1;j>=0;j--){
const b=bullets[j];
if(dist(z,b)<10){

let dmg=b.dmg;
if(Math.random()<0.2) dmg*=2;

// NEW damage numbers
dmgNums.push({x:z.x,y:z.y,val:Math.floor(dmg),life:30});

z.hp-=dmg;
bullets.splice(j,1);

if(z.hp<=0){
player.score+=10;
player.kills++;
zombies.splice(i,1);
break;
}
}
}
}

// dmg numbers update
dmgNums=dmgNums.filter(d=>--d.life>0);
}

// ================= DRAW MAP =================
function drawMap(){
let colors=["#0a0a0a","#102010","#201010"];
ctx.fillStyle=colors[game.biome];
ctx.fillRect(0,0,canvas.width,canvas.height);

// grid world
ctx.strokeStyle="rgba(255,255,255,0.05)";
for(let x=-1000;x<1000;x+=50){
ctx.beginPath();
ctx.moveTo(x-camera.x,-1000-camera.y);
ctx.lineTo(x-camera.x,1000-camera.y);
ctx.stroke();
}
}

// ================= DRAW =================
function draw(){
ctx.save();

drawMap();

// trail
ctx.fillStyle="rgba(0,255,255,0.2)";
trail.forEach(t=>{
ctx.fillRect(t.x-camera.x,t.y-camera.y,4,4);
});

// player
ctx.fillStyle="cyan";
ctx.beginPath();
ctx.arc(player.x-camera.x,player.y-camera.y,10,0,Math.PI*2);
ctx.fill();

// zombies
zombies.forEach(z=>{
ctx.fillStyle=z.color;
ctx.fillRect(z.x-camera.x-5,z.y-camera.y-5,10,10);
});

// bullets
ctx.fillStyle="yellow";
bullets.forEach(b=>{
ctx.fillRect(b.x-camera.x,b.y-camera.y,3,3);
});

// damage numbers
ctx.fillStyle="red";
dmgNums.forEach(d=>{
ctx.fillText(d.val, d.x-camera.x, d.y-camera.y);
});

// UI
ctx.fillStyle="white";
ctx.fillText("HP:"+Math.floor(player.hp),20,20);
ctx.fillText("Score:"+player.score,20,40);
ctx.fillText("Kills:"+player.kills,20,60);

// XP BAR
ctx.fillStyle="gray";
ctx.fillRect(20,80,200,10);
ctx.fillStyle="lime";
ctx.fillRect(20,80,200*(player.xp/player.nextLevel),10);

// reload bar
if(reloading){
ctx.fillStyle="orange";
ctx.fillRect(20,100,100,5);
}

ctx.restore();
}

// ================= LOOP =================
function loop(){
update();
draw();
requestAnimationFrame(loop);
}
loop();

</script>
</body>
</html>
